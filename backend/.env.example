MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/ruro
MONGODB_DATABASE=ruro
JWT_SECRET=replace-with-a-long-random-production-secret
JWT_EXPIRATION_MINUTES=1440
ALLOWED_ORIGINS=http://localhost:5173

# OTP is never returned to the browser.
OTP_EXPIRATION_MINUTES=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_HOURLY_LIMIT=5

# Recommended third-party OTP email sender without owning a domain: SendGrid.
# Create a Single Sender, verify that sender email, then create an API key.
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=your-verified-sender@gmail.com
SENDGRID_FROM_NAME=RURO

# Optional Resend fallback. Resend needs a verified domain for sending to everyone.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Optional SMTP fallback.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-sender@example.com
MAIL_PASSWORD=your-app-password
